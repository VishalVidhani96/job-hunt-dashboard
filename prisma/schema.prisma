generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  New
  Applied
  Interview
  Reject
  Accept
}

enum LanguageCode {
  English
  German
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profiles  CandidateProfile[]
  jobs      Job[]
  syncRuns  SyncRun[]
}

model CandidateProfile {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  summary            String?
  yearsExperience    Int      @default(0)
  skills             String[]
  technologies       String[]
  jobTitles          String[]
  education          String[]
  keywords           String[]
  parsedRawText      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatches         Job[]

  @@index([userId])
}

model Job {
  id                  String       @id @default(cuid())
  userId              String
  profileId           String?
  sourceId            String
  externalId          String?
  title               String
  company             String
  description         String
  summary             String?
  city                String?
  country             String
  requiredLanguage    LanguageCode?
  postedAt            DateTime
  firstSeenAt         DateTime     @default(now())
  lastSeenAt          DateTime     @default(now())
  lastUpdatedAt       DateTime     @updatedAt
  url                 String
  normalizedHash      String
  atsScore            Int          @default(0)
  atsExplanation      String?
  status              JobStatus    @default(New)
  isViewed            Boolean      @default(false)
  isNewToday          Boolean      @default(true)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile             CandidateProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  source              JobSource    @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  statusHistory       JobStatusHistory[]
  notes               JobNote[]
  dedupeMeta          JobDedupMeta?

  @@unique([userId, url])
  @@index([userId, postedAt])
  @@index([userId, status])
  @@index([normalizedHash])
}

model JobSource {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  baseUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
}

model SyncRun {
  id             String   @id @default(cuid())
  userId         String
  trigger        String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  success        Boolean   @default(false)
  insertedCount  Int       @default(0)
  updatedCount   Int       @default(0)
  errorMessage   String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model JobStatusHistory {
  id        String    @id @default(cuid())
  jobId      String
  fromStatus JobStatus?
  toStatus   JobStatus
  createdAt  DateTime @default(now())
  note       String?
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId      String
  content    String
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model JobDedupMeta {
  id               String   @id @default(cuid())
  jobId             String   @unique
  dedupKey          String
  titleFingerprint  String
  companyFingerprint String
  createdAt         DateTime @default(now())
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([dedupKey])
}
